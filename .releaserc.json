{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "release": false },
          { "type": "chore", "release": false },
          { "type": "test", "release": false },
          { "type": "style", "release": false },
          { "type": "ci", "release": false },
          { "type": "build", "release": false },
          { "scope": "no-release", "release": false },
          { "breaking": true, "release": "major" }
        ],
        "parserOpts": {
          "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES", "BREAKING"]
        }
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "✨ Features" },
            { "type": "fix", "section": "🐛 Bug Fixes" },
            { "type": "perf", "section": "⚡ Performance" },
            { "type": "refactor", "section": "♻️ Refactor" },
            { "type": "docs", "section": "📝 Documentation", "hidden": false },
            { "type": "test", "section": "🧪 Tests", "hidden": true },
            { "type": "build", "section": "🔧 Build", "hidden": true },
            { "type": "ci", "section": "🔧 CI", "hidden": true },
            { "type": "chore", "section": "🧰 Maintenance", "hidden": true },
            { "type": "style", "section": "💄 Style", "hidden": true }
          ]
        },
        "writerOpts": {
          "headerPartial": "## {{version}}\n\n{{#if date}}_{{date}}_\n\n{{/if}}"
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to Metano are documented here. The format follows\n[Keep a Changelog](https://keepachangelog.com/en/1.1.0/) and the project\nadheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html)."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "dotnet pack Metano-packages.slnx -c Release -p:Version=${nextRelease.version} -p:PackageVersion=${nextRelease.version} -o ./artifacts && dotnet nuget push './artifacts/*.nupkg' --api-key \"$NUGET_TOKEN\" --source https://api.nuget.org/v3/index.json --skip-duplicate"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false
      }
    ]
  ]
}
