{
  "name": "sample-counter-v4",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3004",
    "build": "tsgo -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "inferno": "^9.0.0",
    "inferno-create-element": "^9.0.0",
    "metano-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "vite": "^8.0.4",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "sideEffects": false,
  "imports": {
    "#/*": {
      "types": "./lib/*",
      "default": "./src/*"
    },
    "#": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
