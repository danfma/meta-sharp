{
  "private": true,
  "workspaces": [
    "targets/js/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260306.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.0"
  },
  "scripts": {
    "dev": "bun run --parallel ts:watch sample-counter-v1 sample-counter-v2 sample-counter-v3 sample-counter-v4 sample-counter-v5",
    "build": "tsgo -b .",
    "ts:watch": "tsgo -b --watch -v",
    "sample-counter-v1": "bun run --cwd ./targets/js/sample-counter-v1 dev",
    "sample-counter-v2": "bun run --cwd ./targets/js/sample-counter-v2 dev",
    "sample-counter-v3": "bun run --cwd ./targets/js/sample-counter-v3 dev",
    "sample-counter-v4": "bun run --cwd ./targets/js/sample-counter-v4 dev",
    "sample-counter-v5": "bun run --cwd ./targets/js/sample-counter-v5 dev"
  },
  "type": "module"
}
